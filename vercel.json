{
  "version": 2,
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    },
    "api/refresh.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/refresh", "destination": "/api/refresh" },
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "crons": [
    {
      "path": "/api/refresh",
      "schedule": "0 0 * * *"
    }
  ]
}
