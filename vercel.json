{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    },
    {
      "src": "api/refresh.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    }
  ],
  "routes": [
    { "src": "/api/refresh", "dest": "/api/refresh.py" },
    { "src": "/(.*)", "dest": "/api/index.py" }
  ],
  "crons": [
    {
      "path": "/api/refresh",
      "schedule": "0 0 * * *"
    }
  ]
}
